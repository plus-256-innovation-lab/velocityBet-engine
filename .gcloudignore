# This file overrides .gitignore for gcloud uploads
.gcloudignore
.git
.gitignore
node_modules/
dist/
.env
*.log

# Keep large runtime assets (gitignored but required for deploy)
!track-snapshot.bin.gz

# Training/dev artifacts not needed in the container (huge — slows uploads)
track-snapshot.bin
marble_race_data.csv
